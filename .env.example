# GitHub App Configuration
GITHUB_APP_ID=your_github_app_id_here
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
WEBHOOK_SECRET=mega_ar_webhook_secret_2024

# Hugging Face Token (for diarization)
HF_TOKEN=hf_your_hugging_face_token_here

# Transcription Settings
DEVICE=cuda
BATCH_SIZE=4
COMPUTE_TYPE=float16
LANGUAGE_CODE=ar

# Quality Settings
DEFAULT_QUALITY=high
LOW_QUALITY_MODEL=base
MEDIUM_QUALITY_MODEL=small
HIGH_QUALITY_MODEL=medium
ULTRA_QUALITY_MODEL=large-v3

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=False

# File Settings
MAX_FILE_SIZE=500  # MB
TEMP_DIR=/tmp/mega_ar
OUTPUT_DIR=./transcriptions

# Initial Prompt for Arabic Context
INITIAL_PROMPT=يا جماعة، موافقون، اعتراض، النصاب القانوني، ميزانية، محضر الجلسة، تصويت، العضو، رئيس مجلس الإدارة